---
const works = [
  { src: '/images/img-01.jpg', alt: 'Holzrahmenbau – Tragwerk im Rohbau', num: '01' },
  { src: '/images/img-02.jpg', alt: 'Dachstuhl aus Massivholz, von innen', num: '02' },
  { src: '/images/img-03.jpg', alt: 'Holzfassade eines fertigen Gebäudes', num: '03' },
  { src: '/images/img-04.jpg', alt: 'Innenausbau mit Massivholz-Details', num: '04' },
];
---

<section id="werke" class="werke">
  <div class="werke-header">
    <span class="werke-label">— Arbeiten</span>
    <h2 class="werke-title">Aus der Werkstatt<br />in den Raum.</h2>
  </div>

  <div class="werke-grid">
    {works.map((w, i) => (
      <figure class={`werke-item werke-item--${i + 1}`} data-werke-item>
        <div class="werke-image-wrap" data-werke-wrap>
          <div class="werke-image-inner" data-werke-parallax>
            <img
              class="werke-image"
              data-werke-image
              src={w.src}
              alt={w.alt}
              loading="lazy"
            />
          </div>
        </div>
        <span class="werke-num" aria-hidden="true">{w.num}</span>
      </figure>
    ))}
  </div>
</section>

<style>
  .werke {
    position: relative;
    padding: 8rem 2rem;
    background: var(--color-meister-bg);
    overflow: hidden;
  }

  .werke-header {
    max-width: 80rem;
    margin: 0 auto 4rem;
  }

  .werke-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-meister-gold);
    margin-bottom: 1.5rem;
  }

  .werke-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0;
    color: var(--color-meister-bone);
  }

  .werke-grid {
    position: relative;
    max-width: 90rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
  }

  .werke-item {
    position: relative;
    margin: 0;
  }

  .werke-item--1 {
    grid-column: 1 / 8;
    grid-row: 1;
    aspect-ratio: 4 / 5;
  }

  .werke-item--2 {
    grid-column: 8 / 13;
    grid-row: 1 / 3;
    aspect-ratio: 3 / 4;
    align-self: end;
    margin-top: 6rem;
  }

  .werke-item--3 {
    grid-column: 1 / 6;
    grid-row: 2;
    aspect-ratio: 1 / 1;
    margin-top: -3rem;
  }

  .werke-item--4 {
    grid-column: 6 / 13;
    grid-row: 3;
    aspect-ratio: 16 / 9;
    margin-top: 1.5rem;
  }

  .werke-image-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--color-meister-line);
  }

  .werke-image-inner {
    position: absolute;
    inset: -10% 0;
    width: 100%;
    height: 120%;
    will-change: transform;
  }

  .werke-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
  }

  .werke-num {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    color: var(--color-meister-bone);
    background: rgba(11, 11, 12, 0.45);
    backdrop-filter: blur(4px);
    padding: 0.4em 0.7em;
    pointer-events: none;
  }

  @media (max-width: 819px) {
    .werke-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .werke-item--1,
    .werke-item--2,
    .werke-item--3,
    .werke-item--4 {
      grid-column: 1 / -1;
      grid-row: auto;
      margin-top: 0;
      align-self: auto;
      aspect-ratio: 4 / 5;
    }
  }
</style>