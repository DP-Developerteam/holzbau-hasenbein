    background: var(--color-meister-bg);
  }

  .manifesto-inner {
    /* max-width: 72rem; */
    /* max-width: 50rem; */
    width: 100%;
  }

  .manifesto-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-meister-gold);
    margin-bottom: 3rem;
  }

  .manifesto-text {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    line-height: 1.25;
    color: var(--color-meister-bone);
    margin: 0;
  }

  .manifesto-signature {
    display: block;
    margin-top: 3rem;
