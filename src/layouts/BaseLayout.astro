---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Ilyas Hasenbein — Holzmeister in Köln. Holzrahmenbau, Dachstühle, Fassaden und Innenausbau aus Massivholz." } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="noise-overlay"></div>
    <slot/>
  </body>
</html>